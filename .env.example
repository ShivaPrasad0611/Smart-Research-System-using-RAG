# Copy this file to ".env" and fill in what you need.
# The app works fully offline with the defaults below (no keys required).

# --- Providers: "huggingface" (local/free) or "openai" (needs API key) ---
EMBEDDING_PROVIDER=huggingface
LLM_PROVIDER=groq

# --- Model names (override if you want different models) ---
# bge-small is a strong quality/speed balance for local, offline retrieval.
# Swap to BAAI/bge-base-en-v1.5 or intfloat/e5-base-v2 for higher quality
# at somewhat higher RAM/latency cost.
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
HF_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
OPENAI_LLM_MODEL=gpt-4o-mini

# --- Groq -- free, very fast hosted inference, no credit card required ---
# Get a key at https://console.groq.com
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY= 
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1_5

# --- API keys (only needed if using the "openai" provider above) ---
OPENAI_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# --- Vector store: "faiss" or "chroma" ---
VECTOR_STORE=faiss
VECTOR_STORE_DIR=data/vectorstore

# --- Device for local HF models: "auto" (default), "cpu", or "cuda" ---
DEVICE=auto

# --- Chunking & retrieval ---
CHUNK_SIZE=400
CHUNK_OVERLAP=80
# Final number of chunks handed to the LLM as context
TOP_K=5
# "similarity" or "mmr" (reduces duplicate/redundant chunks)
SEARCH_TYPE=mmr
# Candidate pool MMR pulls before diversifying down to TOP_K
FETCH_K=20

# --- Reranking (cross-encoder second pass over a candidate shortlist) ---
ENABLE_RERANK=false
RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATE_K=20

# Local model generation length cap - lower = faster, less rambling
MAX_NEW_TOKENS=200

# --- Evaluation ---
# true = use RAGAS (LLM-judged, needs OpenAI); false = fast heuristic scores
ENABLE_RAGAS=false

# --- Paths ---
UPLOAD_DIR=data/uploads
